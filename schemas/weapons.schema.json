{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/weapons.schema.json",
  "title": "Weapons Schema",
  "$comment": "Validates weapon data used by balance and TTK tooling.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "weapons"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema or data version identifier."
    },
    "weapons": {
      "type": "array",
      "minItems": 1,
      "$comment": "Catalog of weapon definitions.",
      "items": { "$ref": "#/$defs/weapon" }
    }
  },
  "$defs": {
    "damageProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["range_m", "body", "head", "leg"],
      "$comment": "Damage values for a specific range band.",
      "properties": {
        "range_m": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "number", "minimum": 0 },
            "max": { "type": "number", "minimum": 0 }
          }
        },
        "body": { "type": "number", "minimum": 0 },
        "head": { "type": "number", "minimum": 0 },
        "leg": { "type": "number", "minimum": 0 }
      }
    },
    "timeToKill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_hp", "shots_to_kill", "time_to_kill_s"],
      "$comment": "Precomputed TTK record for a given target HP.",
      "properties": {
        "target_hp": {
          "type": "integer",
          "minimum": 1,
          "description": "Total target HP assumed for this TTK record (e.g., 100, 150)."
        },
        "shots_to_kill": {
          "type": "integer",
          "minimum": 1
        },
        "time_to_kill_s": {
          "type": "number",
          "minimum": 0,
          "description": "Calculated time to kill in seconds under the defined assumptions."
        },
        "assumptions": {
          "type": "string",
          "description": "Optional note on armor, hit location, or range assumptions."
        }
      }
    },
    "weapon": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category",
        "cost",
        "magazine_size",
        "fire_rate_rps",
        "reload_s",
        "equip_s",
        "damage_profiles",
        "time_to_kill"
      ],
      "$comment": "Top-level weapon model with balance stats.",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "sidearm",
            "smg",
            "rifle",
            "sniper",
            "shotgun",
            "heavy",
            "melee"
          ]
        },
        "cost": { "type": "integer", "minimum": 0 },
        "magazine_size": { "type": "integer", "minimum": 1 },
        "reserve_ammo": { "type": "integer", "minimum": 0 },
        "fire_rate_rps": {
          "type": "number",
          "minimum": 0,
          "description": "Rounds per second."
        },
        "first_shot_spread_deg": { "type": "number", "minimum": 0 },
        "movement_speed_mps": { "type": "number", "minimum": 0 },
        "equip_s": { "type": "number", "minimum": 0 },
        "reload_s": {
          "type": "object",
          "additionalProperties": false,
          "required": ["full", "tactical"],
          "properties": {
            "full": { "type": "number", "minimum": 0 },
            "tactical": { "type": "number", "minimum": 0 }
          }
        },
        "zoom": {
          "type": "object",
          "additionalProperties": false,
          "required": ["multiplier", "has_ads"],
          "properties": {
            "multiplier": { "type": "number", "minimum": 1 },
            "has_ads": { "type": "boolean" }
          }
        },
        "damage_profiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/damageProfile" }
        },
        "time_to_kill": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/timeToKill" }
        },
        "penetration": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "fire_mode": {
          "type": "string",
          "enum": ["auto", "semi", "burst", "charge"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
